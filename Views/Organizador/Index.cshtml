@model IEnumerable<SistemaGestionEventos.Models.OrganizadorModel>

@{
    ViewData["Title"] = "Organizadores";
}

<section class="crud-shell">
    <div class="page-heading">
        <div>
            <h1>Organizadores</h1>
            <p>Administracion del sistema de gestion de eventos.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Nuevo</a>
    </div>

    <div class="table-responsive card shadow-sm border-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr>
                    <th>Nombre</th>
                    <th>Especialidad</th>
                    <th>Telefono</th>
                    <th>Activo</th>
                    <th class="text-end">Acciones</th>
            </tr></thead>
            <tbody>
@foreach (var item in Model) {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Especialidad</td>
                    <td>@item.Telefono</td>
                    <td>@(item.Activo ? "Activo" : "Inactivo")</td>
                    <td class="text-end actions-cell">
                        <a asp-action="Edit" asp-route-id="@item.OrganizadorId" class="btn btn-sm btn-outline-primary">Editar</a>
                        <a asp-action="Details" asp-route-id="@item.OrganizadorId" class="btn btn-sm btn-outline-secondary">Detalles</a>
                        <a asp-action="Delete" asp-route-id="@item.OrganizadorId" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
</section>
