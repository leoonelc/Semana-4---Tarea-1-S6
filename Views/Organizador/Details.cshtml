@model SistemaGestionEventos.Models.OrganizadorModel

@{
    ViewData["Title"] = "Detalle de Organizador";
}

<section class="crud-shell">
    <div class="page-heading">
        <h1>Detalle de Organizador</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <dl class="row mb-0">
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>
            <dt class="col-sm-4">Especialidad</dt>
            <dd class="col-sm-8">@Model.Especialidad</dd>
            <dt class="col-sm-4">Telefono</dt>
            <dd class="col-sm-8">@Model.Telefono</dd>
            <dt class="col-sm-4">Activo</dt>
            <dd class="col-sm-8">@(Model.Activo ? "Activo" : "Inactivo")</dd>
            </dl>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.OrganizadorId" class="btn btn-primary">Editar</a>
    </div>
</section>
