@model SistemaGestionEventos.Models.LugarModel

@{
    ViewData["Title"] = "Detalle de Lugar";
}

<section class="crud-shell">
    <div class="page-heading">
        <h1>Detalle de Lugar</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <dl class="row mb-0">
            <dt class="col-sm-4">Nombre</dt>
            <dd class="col-sm-8">@Model.Nombre</dd>
            <dt class="col-sm-4">Ciudad</dt>
            <dd class="col-sm-8">@Model.Ciudad</dd>
            <dt class="col-sm-4">Capacidad</dt>
            <dd class="col-sm-8">@Model.Capacidad</dd>
            <dt class="col-sm-4">Tipo</dt>
            <dd class="col-sm-8">@Model.Tipo</dd>
            </dl>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.LugarId" class="btn btn-primary">Editar</a>
    </div>
</section>
